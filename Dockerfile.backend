FROM node:20-alpine

RUN apk add --no-cache ffmpeg sqlite

WORKDIR /app

COPY package.json ./
COPY backend/package.json ./backend/

RUN npm install --workspace=backend --omit=dev

COPY backend/ ./backend/
COPY raptor.config.js ./

# Data directories
RUN mkdir -p recordings snapshots streams data

EXPOSE 3000

CMD ["node", "backend/server.js"]

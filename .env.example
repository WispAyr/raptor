# ═══════════════════════════════════════════════════════════════════
# RAPTOR Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Select a setup profile — this determines which services are active.
# Profiles: minimal | single | dual | station | hub | full
#
#   minimal  — no cameras, synthetic demo mode
#   single   — one PTZ camera, direct tracking
#   dual     — wide-field spotter + PTZ tracker hand-off (Sky360-style)
#   station  — remote station reporting to a mission control hub
#   hub      — mission control hub only (aggregates remote stations)
#   full     — everything enabled
#
RAPTOR_PROFILE=single

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
WS_PORT=3000

# ── Camera credentials ───────────────────────────────────────────────
CAMERA_USER=admin
CAMERA_PASS=password

# ── Detection source ─────────────────────────────────────────────────
# Set to RTSP URL, device index (0), or "demo" for synthetic mode
DETECT_SOURCE=demo
# DETECT_SOURCE=rtsp://admin:pass@192.168.1.100/stream1
# DETECT_SOURCE=0

# ── Detection feature flags (overrides profile defaults) ─────────────
# DETECT_YOLO=true         # Enable YOLOv8 classification
# DETECT_FLOW=true         # Enable optical flow velocity analysis
# DETECT_CONSTEL=true      # Enable constellation masking (night mode)
# DETECT_FISHEYE=false     # Enable fisheye dewarping for dome cameras
# DETECT_NIGHT=true        # Enable adaptive night mode preprocessing

# Custom YOLOv8 model path (leave blank to use yolov8n.pt from ultralytics)
# YOLO_MODEL_PATH=./detection/train/runs/train/raptor-sky/weights/best.pt

# ── ZeroMQ (Python detector → Node backend) ──────────────────────────
ZMQ_DETECTION_ENDPOINT=tcp://127.0.0.1:5556

# ── PID tuning — pan axis ────────────────────────────────────────────
PID_PAN_KP=0.4
PID_PAN_KI=0.01
PID_PAN_KD=0.08

# ── PID tuning — tilt axis ───────────────────────────────────────────
PID_TILT_KP=0.4
PID_TILT_KI=0.01
PID_TILT_KD=0.08

# ── Tracking behaviour ───────────────────────────────────────────────
# TRACKING_ENABLED=true
# AUTO_ZOOM=true
# DUAL_CAMERA=false

# ── Auto-zoom tuning ─────────────────────────────────────────────────
# AUTO_ZOOM_CENTRE_THRESHOLD=0.15   # Fraction of frame — trigger zoom in
# AUTO_ZOOM_EDGE_THRESHOLD=0.35     # Fraction of frame — trigger zoom out
# AUTO_ZOOM_DWELL_FRAMES=20         # Frames centred before zoom step
# AUTO_ZOOM_STEP=0.05               # Zoom increment (0..1)

# ── Patrol ───────────────────────────────────────────────────────────
PATROL_RESUME_DELAY_MS=5000

# ── Recording ────────────────────────────────────────────────────────
RECORDINGS_DIR=./recordings
SNAPSHOTS_DIR=./snapshots

# ── Dual-camera / spotter setup (RAPTOR_PROFILE=dual) ────────────────
# SPOTTER_RTSP=rtsp://admin:pass@192.168.1.101/stream1
# SPOTTER_FISHEYE=false        # Set true if spotter is a fisheye dome camera
# SPOTTER_HFOV=90              # Spotter horizontal field of view (degrees)
# SPOTTER_VFOV=60              # Spotter vertical field of view (degrees)
# SPOTTER_HOME_AZ=0            # Azimuth the spotter faces at default position (0=North)

# ── Camera position (for az/el coordinate mapping) ───────────────────
# STATION_LAT=51.5074
# STATION_LON=-0.1278
# STATION_ALT=50               # Metres above sea level
# CAMERA_HOME_AZ=0             # PTZ home azimuth (compass degrees, 0=North)
# CAMERA_HFOV=60               # PTZ horizontal field of view (degrees)
# CAMERA_VFOV=34               # PTZ vertical field of view (degrees)

# ── ADS-B cross-reference ────────────────────────────────────────────
# ADSB_ENABLED=true
# ADSB_HOST=localhost           # dump1090 host
# ADSB_PORT=8080               # dump1090 port
# ADSB_RADIUS_NM=25            # Aircraft radius to monitor (nautical miles)
# FLIGHTAWARE_API_KEY=         # Optional: FlightAware AeroAPI key

# ── Weather (Open-Meteo — no API key required) ───────────────────────
# WEATHER_ENABLED=true
# Weather uses STATION_LAT/STATION_LON above

# ── SDR (optional — requires RTL-SDR hardware) ───────────────────────
# SDR_ENABLED=false
# SDR_FREQ_MIN_MHZ=25
# SDR_FREQ_MAX_MHZ=1750

# ── Magnetometer (optional — requires I2C/USB sensor) ────────────────
# MAGNETOMETER_DEVICE=/dev/i2c-1

# ── GPS (optional — improves triangulation accuracy) ─────────────────
# GPS_PORT=/dev/ttyUSB0
# GPS_BAUD=9600

# ── Mission control (RAPTOR_PROFILE=station or hub) ──────────────────
# STATION_ID=raptor-1
# MISSION_HUB_URL=ws://192.168.1.50:3001    # Hub URL for station mode
# HUB_PORT=3001                             # Hub listen port (hub mode)

# ── Ecosystem integrations ───────────────────────────────────────────
# SKYTRACK_WS_URL=ws://localhost:4000       # SKYTRACK DroneVoxelServer WebSocket
# PRISM_URL=http://localhost:4001           # Prism intelligence hub URL
# NURO_WEBHOOK_URL=http://localhost:5000/api/alerts
# AIRWAVE_WS_URL=ws://localhost:3002        # AirWave ADS-B WebSocket feed

# ── HLS streaming ────────────────────────────────────────────────────
# HLS_ENABLED=true
# HLS_OUTPUT_DIR=./streams


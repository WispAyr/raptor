PORT=3000
WS_PORT=3000

# Camera credentials (default)
CAMERA_USER=admin
CAMERA_PASS=password

# Detection ZeroMQ endpoint (Python detector publishes here)
ZMQ_DETECTION_ENDPOINT=tcp://127.0.0.1:5556

# PID tuning (pan axis)
PID_PAN_KP=0.4
PID_PAN_KI=0.01
PID_PAN_KD=0.08

# PID tuning (tilt axis)
PID_TILT_KP=0.4
PID_TILT_KI=0.01
PID_TILT_KD=0.08

# Patrol: resume delay after tracking ends (ms)
PATROL_RESUME_DELAY_MS=5000

# Recording output directory
RECORDINGS_DIR=./recordings
SNAPSHOTS_DIR=./snapshots

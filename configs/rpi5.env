# RAPTOR — Raspberry Pi 5 Performance Profile
# Target: 15fps detection using ONNX Runtime (CPU)

# Detection
DETECT_SOURCE=rtsp://admin:pass@192.168.1.100/stream1
DETECT_YOLO=true
DETECT_FLOW=true
DETECT_CONSTEL=true
DETECT_NIGHT=true
DETECT_FISHEYE=false

# Use ONNX model for faster CPU inference on Pi 5
# Export with: yolo export model=yolov8n.pt format=onnx
# YOLO_MODEL_PATH=./detection/train/weights/yolov8n.onnx

# Lower process resolution for Pi 5 CPU
# DETECT_PROCESS_W=320
# DETECT_PROCESS_H=180

# Disable YOLOv8 classification if < 15fps (run blob only)
# DETECT_YOLO=false

# ZMQ
ZMQ_DETECTION_ENDPOINT=tcp://0.0.0.0:5556

# Pi 5 has no GPU — use CPU HLS encoding (slower)
HLS_ENABLED=true

# GPS via USB serial (common Pi setup)
# GPS_PORT=/dev/ttyUSB0
# GPS_BAUD=9600

# Weather
WEATHER_ENABLED=true

# Tips for Pi 5:
# - Use USB 3.0 SSD for recordings (SD card too slow for video write)
# - Use PoE HAT for network + power in single cable
# - Target: 15fps with ONNX YOLOv8n, 25fps with blob-only detection

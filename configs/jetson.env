# RAPTOR — Jetson Nano/Orin Performance Profile
# Use with: RAPTOR_PROFILE=single + these overrides

# Detection
DETECT_SOURCE=rtsp://admin:pass@192.168.1.100/stream1
DETECT_YOLO=true
DETECT_FLOW=true
DETECT_CONSTEL=true
DETECT_NIGHT=true
DETECT_FISHEYE=false

# Use TensorRT-optimised model export for maximum speed
# Export with: yolo export model=yolov8n.pt format=engine device=0
# Then set:
# YOLO_MODEL_PATH=./detection/train/weights/yolov8n.engine

# Jetson-specific: use GPU device
# CUDA_VISIBLE_DEVICES=0

# Process resolution (lower = faster on Jetson Nano)
# DETECT_PROCESS_W=480
# DETECT_PROCESS_H=270

# ZMQ — bind on all interfaces for Docker network
ZMQ_DETECTION_ENDPOINT=tcp://0.0.0.0:5556

# HLS streaming (hardware h264 encoder)
HLS_ENABLED=true
# Add to ffmpeg args: -c:v h264_nvenc (Jetson NVENC)

# Weather (requires internet)
WEATHER_ENABLED=true

# Target performance: 30fps detection on Jetson Nano, 60fps on Orin
